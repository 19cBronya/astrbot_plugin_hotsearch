{
  "api_key": {
    "description": "全局API密钥",
    "type": "string",
    "hint": "统一密钥，所有接口共享",
    "default": ""
  },
  "enable_memory_filter": {
    "description": "启用AI偏好过滤推荐",
    "type": "bool",
    "hint": "开启后，无论原配置为何种格式，都会强制使用文本请求，并结合你填写的偏好内容推荐感兴趣的热点。",
    "default": false
  },
  "user_preference": {
    "description": "自定义偏好内容",
    "type": "string",
    "hint": "当启用AI偏好过滤推荐时，请填写你感兴趣的内容（如：科技、游戏、前端开发）。留空则让大模型自行发挥。",
    "default": ""
  },
  "groups": {
    "description": "推送群组列表",
    "type": "list",
    "hint": "填入群组的唯一标识符（Platform:GroupMessage:ID）",
    "default": []
  },
  "push_time": {
    "description": "推送时间",
    "type": "string",
    "hint": "定时推送时间，支持多个时间点用逗号分隔，如: 08:00,12:00",
    "default": ""
  },
  "push_items": {
    "description": "定时推送内容",
    "type": "list",
    "hint": "选择要定时推送的热搜平台",
    "options": [
      "douyin", "xhs", "zhihu", "weibo", "baidu", "dcd", "bilibili", 
      "toutiao", "tencent", "quark", "maoyan", "douban", "kr36", 
      "cto51", "pojie52", "acfun", "csdn", "hellogithub", "miyoushe", 
      "ifanr", "ithome", "juejin", "netease", "sina", "sspai", 
      "thepaper", "weatheralarm", "weread", "yicai", "yystv",
      "cls", "kuaishou", "hykb"
    ],
    "default": ["weibo"]
  },
  "timeout": {
    "description": "请求超时时间(秒)",
    "type": "int",
    "hint": "API请求的超时时间，默认30秒",
    "default": 30
  },
  "enable_douyin": {
    "description": "开启或关闭抖音热搜",
    "type": "bool",
    "default": true
  },
  "douyin_api": {
    "description": "抖音热搜API",
    "type": "string",
    "hint": "使用 https://api.nycnm.cn/api/v2/douyinrs 接口，参数 ?format=text/image",
    "obvious_hint": true,
    "default": "https://api.nycnm.cn/api/v2/douyinrs"
  },
  "douyin_format": {
    "description": "抖音接口返回格式",
    "type": "string",
    "hint": "支持 text/image 两种",
    "options": ["text", "image"],
    "default": "image"
  },
